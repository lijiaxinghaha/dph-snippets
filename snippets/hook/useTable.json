{
  "Use Table": {
    "prefix": ["use_table", "dph_use_table"],
    "body": [
      "useTable({",
      "  action: (a, b, params) => {",
      "    let createTimeS = null,",
      "      createTimeE = null;",
      "    if (params.createTimeStartTime && params.createTimeEndTime) {",
      "      createTimeS = params.createTimeStartTime;",
      "      createTimeE = params.createTimeEndTime + ' 23:59:59';",
      "    }",
      "    const { createTimeStartTime, createTimeEndTime, ...rest } = params;",
      "    return getList(a, b, { ...rest, createTimeS, createTimeE });",
      "  },",
      "  rangeTime: ['createTime'],",
      "  //导出 ",
      "  exportConfig: params => ['/api/export', params!, '导出文件名'],",
      " //默认查询条件",
      "  initSearch: () => ({ status: '1' }),",
      "});"
    ],
    "description": "useTable 使用"
  },
  "Common Columns": {
    "prefix": ["cT", "dph_cT"],
    "body": [
      "cT('name', '名称'，110, true),",
      "// 系统字典列createTableSelect/业务字典createBizTableSelect",
      "cT('status', '状态', { ...createTableSelect('dic_status') }),",
      "cT('numSelect', '数字字典', { ...formatterNumber(createTableSelect('xxx')) }, 100, true),",
      "cT(",
      "  'custom',",
      "  '自定义',",
      "  {",
      "    type: 'date',",
      "    render() {",
      "      return '123';",
      "    },",
      "  },",
      "  100,",
      "  true",
      "),",
      "cT(",
      "  'xxx',",
      "  'xxx时间',",
      "  {",
      "    type: 'datetime',",
      "    format: 'YYYY-MM-DD HH:mm:ss',",
      "    valueFormat: 'YYYY-MM-DD HH:mm:ss',",
      "    searchSpan: 8,",
      "    searchRange: true,",
      "  },",
      "  true",
      "),",
      "cT(",
      "  'tagNames',",
      "  '标签',",
      "  {",
      "    type: 'tree',",
      "    dicUrl: '/psc/dictTag/listTree',",
      "    props: {",
      "      label: 'label',",
      "      value: 'id',",
      "      children: 'children',",
      "    },",
      "    defaultExpandAll: true,",
      "  },",
      "  290,",
      "  true",
      "),"
    ],
    "description": "表格列"
  }
}
