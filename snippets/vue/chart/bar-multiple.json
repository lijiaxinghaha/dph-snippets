{
  "Multiple Bar Chart setOptions": {
    "prefix": "ch_bar_multi",
    "body": [
      "${1:chartMultiBarRef}.value.setOptions(",
      "  multipleBarOptions(",
      "    ${2:data}.map(item => ({ name: item.name, data: item.data })),",
      "    {",
      "      top: 32,",
      "      bottom: 40,",
      "      left: 10,",
      "      right: 20,",
      "      visibleCount: 8,",
      "      showDataZoom: ${2:data}[0]?.data?.length > 8 ? true : false,",
      "      yMinInterval: 1,",
      "      lineColor: '#2855B3',",
      "      area: ['#2378f7', '#83bff6'],",
      "    }",
      "  )",
      ")"
    ],
    "description": "多柱图 setOptions"
  }
}
